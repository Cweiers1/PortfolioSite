---
import BaseLayout from '../layouts/BaseLayout.astro';
import corkboard from '../assets/cork-board.png';
---
<BaseLayout title="Contact">

  <!-- Header banner -->
  <div class="relative bg-dark-olive py-12 px-8 text-center overflow-hidden">
    <div class="absolute inset-0 opacity-15" style={`background-image: url('${corkboard.src}'); background-repeat: repeat;`} aria-hidden="true"></div>
    <div class="relative z-10">
      <h1 class="text-5xl font-light tracking-wide text-warm-white" style="font-family: var(--font-display)">Get in Touch</h1>
      <p class="text-warm-white/55 mt-3 text-sm">Comstock Park, MI — available for local and remote projects</p>
    </div>
  </div>

  <div class="max-w-2xl mx-auto px-8 py-14">
    <p class="text-near-black/50 mb-10">Tell me about what you're working on and I'll get back to you.</p>

    <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6">
      <input type="hidden" name="access_key" value="bba078ab-2d16-4642-919f-a3cbb417aa89">
      <input type="checkbox" name="botcheck" class="hidden" style="display: none;">
      <div class="flex flex-col gap-1.5">
        <label for="name" class="text-xs font-medium tracking-widest uppercase text-near-black/50">Name</label>
        <input
          type="text"
          id="name"
          name="name"
          required
          placeholder="Jane Smith"
          class="border border-near-black/20 rounded-lg px-4 py-3 text-near-black bg-white placeholder:text-near-black/30 focus:outline-none focus:ring-2 focus:ring-deep-rose focus:border-transparent transition-shadow"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="phone" class="text-xs font-medium tracking-widest uppercase text-near-black/50">Phone</label>
        <input
          type="tel"
          id="phone"
          name="phone"
          placeholder="(555) 000-0000"
          class="border border-near-black/20 rounded-lg px-4 py-3 text-near-black bg-white placeholder:text-near-black/30 focus:outline-none focus:ring-2 focus:ring-deep-rose focus:border-transparent transition-shadow"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="email" class="text-xs font-medium tracking-widest uppercase text-near-black/50">Email</label>
        <input
          type="email"
          id="email"
          name="email"
          required
          placeholder="jane@example.com"
          class="border border-near-black/20 rounded-lg px-4 py-3 text-near-black bg-white placeholder:text-near-black/30 focus:outline-none focus:ring-2 focus:ring-deep-rose focus:border-transparent transition-shadow"
        />
      </div>

      <div class="flex flex-col gap-1.5">
        <label for="message" class="text-xs font-medium tracking-widest uppercase text-near-black/50">How can I help?</label>
        <textarea
          id="message"
          name="message"
          required
          rows="6"
          placeholder="Describe the services you're looking for..."
          class="border border-near-black/20 rounded-lg px-4 py-3 text-near-black bg-white placeholder:text-near-black/30 focus:outline-none focus:ring-2 focus:ring-deep-rose focus:border-transparent resize-y transition-shadow"
        ></textarea>
      </div>

      <button
        type="submit"
        class="self-start bg-deep-rose hover:bg-deep-rose/85 text-warm-white text-sm font-medium tracking-wide px-7 py-3 rounded-lg transition-colors"
      >
        Send Message
      </button>

    </form>
  </div>

</BaseLayout>
