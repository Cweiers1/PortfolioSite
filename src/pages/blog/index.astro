---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogPostCard from '../../components/BlogPostCard.astro';
import { getCollection } from 'astro:content';
import corkboard from '../../assets/cork-board.png';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);
---
<BaseLayout title="Blog">

  <!-- Header banner -->
  <div class="relative bg-dark-olive py-12 px-8 text-center overflow-hidden">
    <div class="absolute inset-0 opacity-15" style={`background-image: url('${corkboard.src}'); background-repeat: repeat;`} aria-hidden="true"></div>
    <div class="relative z-10">
      <h1 class="text-5xl font-light tracking-wide text-warm-white" style="font-family: var(--font-display)">Blog</h1>
    </div>
  </div>

  <!-- Post list -->
  <div class="max-w-3xl mx-auto px-8 divide-y divide-near-black/15">
    {posts.map(post => (
      <BlogPostCard
        title={post.data.title}
        date={post.data.pubDate}
        slug={post.id}
        icon={post.data.icon}
      />
    ))}
  </div>

</BaseLayout>
