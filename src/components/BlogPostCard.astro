---
interface Props {
  title: string;
  date: Date;
  slug: string;
  icon?: string;
}

const { title, date, slug, icon = '?' } = Astro.props;

const formatted = date.toLocaleDateString('en-US', {
  month: 'short',
  day: '2-digit',
  year: 'numeric',
});

const iconColorMap: Record<string, string> = {
  '{ }': 'bg-dark-olive text-warm-white',
  'UI':  'bg-near-black text-warm-white',
  '>_':  'bg-deep-rose text-warm-white',
  'JS':  'bg-amber text-near-black',
  'API': 'bg-deep-rose text-warm-white',
};
const iconClass = iconColorMap[icon] ?? 'bg-near-black/40 text-warm-white';
---
<a href={`/blog/${slug}`} class="flex items-center gap-4 py-4 hover:bg-near-black/5 transition-colors">
  <div class={`${iconClass} rounded-xl w-12 h-12 flex items-center justify-center text-xs font-bold shrink-0`}>
    {icon}
  </div>
  <div>
    <p class="font-semibold text-near-black text-base">{title}</p>
    <p class="text-near-black/50 text-sm mt-0.5">{formatted}</p>
  </div>
</a>
